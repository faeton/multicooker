#!/bin/sh
# Example entrypoint for a custom flavor. Copy to your flavor's directory
# (templates/cook/participants/<flavor>/entrypoint.sh) and fill in TODOs.
#
# CONTRACT (must hold for both modes):
#   read    /work/PROMPT.txt          (participant mode)  ── what to do
#   read    /work/JUDGE_BRIEF.md      (judge mode)        ── how to score
#   read    /work/raw/                                    ── reference material
#   write   /work/out/RESULT.md       (participant mode)  ── single-file output
#   write   /work/outbox/scores.json  (judge mode)        ── strict JSON, see JUDGE_BRIEF
#   write   /work/outbox/review.md    (judge mode)        ── prose, anonymized labels
#
# Modes are switched by env: MULTIVARKA_JUDGE set ⇒ judge mode.
# MULTIVARKA_MODEL is optional and may or may not apply (forward to your
# CLI's --model / -m / -c model=... if it has one; ignore otherwise).
#
# IMPORTANT: use your CLI's permission-bypass / non-interactive flag.
# Without it the CLI hangs on the first "may I write to ./out/RESULT.md?
# [y/N]" prompt and the wall-clock timer kills the round. Inside this
# container, "dangerous" flags are the *correct* setting — the container
# itself is the sandbox.

set -e

PROMPT_FILE="/work/PROMPT.txt"
OUT_DIR="/work/out"
OUTBOX="/work/outbox"

if [ -n "$MULTIVARKA_JUDGE" ]; then
    mkdir -p "$OUTBOX"
    # TODO: invoke your CLI in non-interactive mode, give it
    # /work/JUDGE_BRIEF.md as the task and /work/submissions/ as the
    # material to score. Tell it to write JSON to $OUTBOX/scores.json
    # and prose to $OUTBOX/review.md. Example for a hypothetical "agent" CLI:
    #
    #   agent run --yolo \
    #       --prompt-file /work/JUDGE_BRIEF.md \
    #       --add-dir /work/submissions \
    #       --output-dir "$OUTBOX"
    #
    # If your CLI takes a model flag and MULTIVARKA_MODEL is set, forward it.
    echo "TODO: implement judge mode for this flavor" >&2
    exit 64
fi

# Participant mode.
[ -f "$PROMPT_FILE" ] || { echo "no $PROMPT_FILE" >&2; exit 64; }
mkdir -p "$OUT_DIR"

# TODO: invoke your CLI. The prompt is in $PROMPT_FILE; reference material
# in /work/raw/; results go to $OUT_DIR/RESULT.md (and any other files the
# brief asks for). Example shapes per existing flavor:
#
#   # claude (prompt MUST come before --add-dir, otherwise the variadic
#   # flag swallows it)
#   claude --print "$(cat $PROMPT_FILE)" \
#          --dangerously-skip-permissions \
#          --add-dir /work \
#          ${MULTIVARKA_MODEL:+--model "$MULTIVARKA_MODEL"}
#
#   # codex
#   codex exec --cd /work --skip-git-repo-check \
#         --dangerously-bypass-approvals-and-sandbox \
#         ${MULTIVARKA_MODEL:+-c "model=$MULTIVARKA_MODEL"} \
#         "$(cat $PROMPT_FILE)"
#
#   # gemini
#   gemini --yolo \
#          ${MULTIVARKA_MODEL:+--model "$MULTIVARKA_MODEL"} \
#          -p "$(cat $PROMPT_FILE)"

echo "TODO: implement participant mode for this flavor" >&2
exit 64
